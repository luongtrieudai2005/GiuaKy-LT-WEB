# ============================================================
# .env.example — copy this file to .env and fill in your values
# NEVER commit .env to git (it is in .gitignore)
# ============================================================

# --- MongoDB ---
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123

# Full connection string — uses container name "mongo" as host
# Format: mongodb://username:password@host:port/
MONGODB_URL=mongodb://admin:admin123@mongo:27017/?authSource=admin

# The database name inside MongoDB
MONGODB_DB_NAME=taskmanager

# --- JWT Authentication ---
# Generate a strong random key:  openssl rand -hex 32
SECRET_KEY=changeme_replace_with_openssl_rand_hex_32

# Token expiry in minutes (60 = 1 hour, 1440 = 1 day)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Domain (used by nginx and certbot) ---
DOMAIN=yourdomain.com
